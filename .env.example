# Copy to .env and fill in the values for the providers you'll use.
# Each config file in configs/lm and configs/vlm is tagged with its provider
# suffix (-vertex, -studio, -openrouter, -vllm-local, -vllm-remote) — only
# the env vars for providers you actually pick are required.

# --- Google AI Studio (gemini-*-studio configs) -----------------------------
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Vertex AI (gemini-*-vertex configs) ------------------------------------
# Auth via: `gcloud auth application-default login` with a GCP project
# that has the Vertex AI API enabled. litellm reads project/location from
# VERTEXAI_PROJECT / VERTEXAI_LOCATION (or GOOGLE_APPLICATION_CREDENTIALS for
# a service-account JSON).
VERTEXAI_PROJECT=
VERTEXAI_LOCATION=global

# --- OpenRouter (*-openrouter configs) --------------------------------------
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- Self-hosted vLLM (qwen27b-vllm-* configs) ------------------------------
# Optional override. If unset, the configs use the hardcoded api_base
# (http://localhost:8927/v1 for -local, :8928 for -remote). Edit the config
# files or pass `lm.api_base=http://host:port/v1` on the CLI to point
# elsewhere.
HOSTED_VLLM_API_BASE=

# --- Dataset (required) -----------------------------------------------------
# HuggingFace token for downloading VLR-CVC/DocVQA-2026. Needed even if the
# dataset is public, since the hub rate-limits anonymous requests.
HF_TOKEN=

# --- Optional: Logfire tracing ----------------------------------------------
# If set, run URLs are printed to the eval log and traces are streamed.
LOGFIRE_TOKEN=
LOGFIRE_PROJECT_URL=
